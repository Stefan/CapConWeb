NEXT_PUBLIC_SITE_URL=https://capcon.io
NEXT_PUBLIC_APP_URL=https://app.capcon.io
NEXT_PUBLIC_CONTACT_EMAIL=kontakt@capcon.io

# Upstash Redis / Vercel KV — production rate limiting for /api/demo-request
# Vercel: Marketplace → Redis (Upstash) → Connect to CapConWeb
# Preferred (Upstash integration):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV env names are also supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Slack Incoming Webhook (recommended):
# 1. Slack → Apps → Incoming Webhooks → Add to workspace → choose #sales or #demo
# 2. Copy URL and set SLACK_DEMO_WEBHOOK_URL
# SLACK_DEMO_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX
#
# Optional generic webhook (CRM, Zapier, Make). Slack URLs are auto-formatted.
# DEMO_FORM_WEBHOOK_URL=https://hooks.example.com/demo
# Legacy client-side endpoint override (prefer /api/demo-request)
# NEXT_PUBLIC_DEMO_FORM_ENDPOINT=

# Legal notice — REQUIRED before public launch (production env on Vercel)
NEXT_PUBLIC_LEGAL_COMPANY=CapCon GmbH
NEXT_PUBLIC_LEGAL_LEGAL_FORM=Gesellschaft mit beschränkter Haftung
NEXT_PUBLIC_LEGAL_ADDRESS_LINE1=Musterstraße 1
NEXT_PUBLIC_LEGAL_ADDRESS_LINE2=80331 München, Deutschland
NEXT_PUBLIC_LEGAL_PHONE=+49 89 0000000
NEXT_PUBLIC_LEGAL_REGISTER_COURT=Amtsgericht München
NEXT_PUBLIC_LEGAL_REGISTER_NUMBER=HRB 000000
NEXT_PUBLIC_LEGAL_VAT_ID=DE000000000
NEXT_PUBLIC_LEGAL_RESPONSIBLE=Max Mustermann
NEXT_PUBLIC_LEGAL_DPO_EMAIL=privacy@capcon.io
NEXT_PUBLIC_LEGAL_HOSTING_PROVIDER=Vercel Inc.
NEXT_PUBLIC_LEGAL_HOSTING_REGION=United States / EU (region-dependent)
